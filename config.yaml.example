# Pelemello configuration
stt:
  # whisper.cpp HTTP server (already running on port 9000)
  whisper_url: "http://127.0.0.1:9000"
  language: "auto"   # set to "en" etc. to force a specific language
  response_format: "text"

discord:
  # Default webhook URL (can also be set per-project)
  webhook_url: ""
